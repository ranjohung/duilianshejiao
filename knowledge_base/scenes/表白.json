{
  "scene_id": "表白",
  "scene_name": "表白",
  "version": "1.0",
  "scripts": [
    {
      "id": "bb_001",
      "round": 1,
      "purpose": "鼓起勇气",
      "user_emotion": ["紧张"],
      "coach_style": ["鼓励型", "支持型"],
      "level": "安全型",
      "text": "我有话想跟你说，可能有点紧张，但我必须说出来。",
      "tags": ["鼓起勇气", "紧张", "必须说"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_002",
      "round": 1,
      "purpose": "鼓起勇气",
      "user_emotion": ["紧张", "期待"],
      "coach_style": ["鼓励型"],
      "level": "自信型",
      "text": "我喜欢你，想跟你在一起，你愿意吗？",
      "tags": ["鼓起勇气", "直接", "表白"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_003",
      "round": 2,
      "purpose": "真诚表达",
      "user_emotion": ["期待"],
      "coach_style": ["支持型"],
      "level": "安全型",
      "text": "认识你这么久，我发现自己越来越喜欢你，希望能有机会照顾你。",
      "tags": ["真诚表达", "喜欢", "照顾"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_004",
      "round": 2,
      "purpose": "真诚表达",
      "user_emotion": ["平静"],
      "coach_style": ["分析型"],
      "level": "理性型",
      "text": "经过深思熟虑，我觉得你就是我想找的那个人，希望能和你交往。",
      "tags": ["真诚表达", "深思熟虑", "交往"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_005",
      "round": 3,
      "purpose": "具体理由",
      "user_emotion": ["自信"],
      "coach_style": ["挑战型"],
      "level": "自信型",
      "text": "我喜欢你的善良、你的笑容、还有你对待生活的态度，想和你一起走下去。",
      "tags": ["具体理由", "善良", "笑容"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_006",
      "round": 3,
      "purpose": "具体理由",
      "user_emotion": ["期待"],
      "coach_style": ["鼓励型"],
      "level": "幽默型",
      "text": "跟你在一起的每一天都很开心，我想把这种开心延续下去，做我女朋友/男朋友吧！",
      "tags": ["具体理由", "开心", "延续"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_007",
      "round": 4,
      "purpose": "尊重选择",
      "user_emotion": ["平静"],
      "coach_style": ["支持型"],
      "level": "安全型",
      "text": "不管你的答案是什么，我都尊重你的选择，希望我们还能做朋友。",
      "tags": ["尊重选择", "尊重", "朋友"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_008",
      "round": 4,
      "purpose": "尊重选择",
      "user_emotion": ["平静"],
      "coach_style": ["分析型"],
      "level": "理性型",
      "text": "我不想给自己留下遗憾，所以我选择告诉你我的心意，无论结果如何我都接受。",
      "tags": ["尊重选择", "不遗憾", "接受"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_009",
      "round": 5,
      "purpose": "接受结果",
      "user_emotion": ["开心"],
      "coach_style": ["鼓励型"],
      "level": "幽默型",
      "text": "太好了！我一定会好好对你，不让你失望！",
      "tags": ["接受结果", "开心", "好好对"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_010",
      "round": 5,
      "purpose": "接受结果",
      "user_emotion": ["沮丧"],
      "coach_style": ["支持型"],
      "level": "安全型",
      "text": "谢谢你的坦诚，我尊重你的决定，希望你能找到幸福。",
      "tags": ["接受结果", "尊重", "幸福"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_011",
      "round": 1,
      "purpose": "选择时机",
      "user_emotion": ["平静"],
      "coach_style": ["分析型"],
      "level": "理性型",
      "text": "现在方便吗？我想跟你说件重要的事。",
      "tags": ["选择时机", "方便", "重要"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_012",
      "round": 2,
      "purpose": "制造氛围",
      "user_emotion": ["期待"],
      "coach_style": ["鼓励型"],
      "level": "幽默型",
      "text": "今天想带你去一个特别的地方，希望你喜欢。",
      "tags": ["制造氛围", "特别", "喜欢"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_013",
      "round": 3,
      "purpose": "准备礼物",
      "user_emotion": ["期待"],
      "coach_style": ["支持型"],
      "level": "安全型",
      "text": "这是我为你准备的礼物，希望你能喜欢。",
      "tags": ["准备礼物", "礼物", "喜欢"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_014",
      "round": 4,
      "purpose": "保持尊严",
      "user_emotion": ["平静"],
      "coach_style": ["挑战型"],
      "level": "自信型",
      "text": "无论你的答案是什么，我都不会纠缠，希望我们能保持体面。",
      "tags": ["保持尊严", "不纠缠", "体面"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_015",
      "round": 5,
      "purpose": "表达感谢",
      "user_emotion": ["平静"],
      "coach_style": ["支持型"],
      "level": "安全型",
      "text": "谢谢你给我机会表达我的心意，无论结果如何，我都很感激。",
      "tags": ["表达感谢", "机会", "感激"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_016",
      "round": 1,
      "purpose": "线上表白",
      "user_emotion": ["紧张"],
      "coach_style": ["鼓励型"],
      "level": "安全型",
      "text": "有些话当面说不出口，但我必须告诉你：我喜欢你。",
      "tags": ["线上表白", "说不出口", "喜欢"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_017",
      "round": 2,
      "purpose": "手写情书",
      "user_emotion": ["期待"],
      "coach_style": ["支持型"],
      "level": "安全型",
      "text": "这是我写的信，希望你能认真看看。",
      "tags": ["手写情书", "信", "认真"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_018",
      "round": 3,
      "purpose": "朋友见证",
      "user_emotion": ["紧张"],
      "coach_style": ["鼓励型"],
      "level": "自信型",
      "text": "今天想让朋友们见证，我想正式向你表白。",
      "tags": ["朋友见证", "见证", "正式"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_019",
      "round": 4,
      "purpose": "循序渐进",
      "user_emotion": ["平静"],
      "coach_style": ["分析型"],
      "level": "理性型",
      "text": "我不想给你压力，如果你还没准备好，可以慢慢考虑。",
      "tags": ["循序渐进", "压力", "考虑"],
      "usage_count": 0,
      "rating": 0
    },
    {
      "id": "bb_020",
      "round": 5,
      "purpose": "收尾",
      "user_emotion": ["平静"],
      "coach_style": ["分析型"],
      "level": "理性型",
      "text": "无论结果如何，我都不后悔今天说出来。",
      "tags": ["收尾", "不后悔", "说出来"],
      "usage_count": 0,
      "rating": 0
    }
  ]
}